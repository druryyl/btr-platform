VITE_API_BASE_URL=http://localhost:5050
# IIS application path prefix (leading and trailing slash required). Must match the deployed site path.
# Must match the IIS application URL path exactly (e.g. /portal/ or /btr-portal/).
VITE_BASE_PATH=/portal/

# Production: copy to .env.production (gitignored) or set before `npm run build`, e.g.:
#   $env:VITE_API_BASE_URL = "http://server:8080/api"
# Use the hostname clients use in the browser — not localhost unless users browse via localhost.
